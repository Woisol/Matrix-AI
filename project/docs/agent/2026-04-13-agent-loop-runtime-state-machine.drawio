                <mxCell id="22" value="IN_THINK&lt;br&gt;追加到 draftText(type=think)&lt;br&gt;即时更新 UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="20" vertex="1">
