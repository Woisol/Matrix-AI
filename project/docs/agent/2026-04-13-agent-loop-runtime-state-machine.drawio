                </mxCell>
                <mxCell id="24" value="IN_TOOL_CALL_JSON&lt;br&gt;累积 JSON 文本到 parser.buffer&lt;br&gt;此时不执行工具" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="20" vertex="1">
