                </mxCell>
                <mxCell id="25" value="VALIDATE_TOOL_CALL&lt;br&gt;JSON.parse&lt;br&gt;校验 toolName / input[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="20" vertex="1">
                    <mxGeometry x="220" y="500" width="200" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="26" value="EMIT_TOOL_CALL_READY&lt;br&gt;输出 parser 事件：toolCallReady&lt;br&gt;runState 才会跳去 EXECUTE_TOOL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="20" vertex="1">
                    <mxGeometry x="220" y="640" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="27" value="PARSER_ERROR&lt;br&gt;出现已闭合但无效 JSON&lt;br&gt;结束本轮为 client_error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="20" vertex="1">
                    <mxGeometry x="40" y="640" width="150" height="80" as="geometry"/>
