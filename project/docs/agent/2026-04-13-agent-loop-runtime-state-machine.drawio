                    <mxGeometry x="30" y="90" width="120" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="QUEUE_EVENT_BATCH&lt;br&gt;只入队已完成事件：&lt;br&gt;user_message / sealed think / sealed output / tool_call / tool_result / turn_end" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="30" vertex="1">
