            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="&lt;b&gt;Matrix Agent Loop v2：实现级状态机草图&lt;/b&gt;&lt;br&gt;重点不是职责分工，而是 run state / parser state / persist sidecar 如何协同运行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="20" y="20" width="1730" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="AgentRun（单轮对象，发送一条 user_message 就创建一次）&lt;br&gt;持有字段：runId / conversationId / abortController / stepIndex / consecutiveToolFailures / expectedEventCount / toolSnapshot / parser.mode / parser.buffer / draftText / persistQueue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="20" y="90" width="1730" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="Run State Machine" style="swimlane;startSize=30;rounded=1;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="20" y="180" width="760" height="1140" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="IDLE" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="10" vertex="1">
                    <mxGeometry x="40" y="70" width="120" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="START_RUN&lt;br&gt;创建 AgentRun&lt;br&gt;冻结本轮 toolSnapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="10" vertex="1">
                    <mxGeometry x="40" y="170" width="180" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="ENQUEUE_USER_EVENT&lt;br&gt;本地 append user_message&lt;br&gt;queue.enqueue(user_message)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="10" vertex="1">
                    <mxGeometry x="40" y="290" width="210" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="14" value="BUILD_STEP_REQUEST&lt;br&gt;基于已知 conversation.events + 本轮已确认事件&lt;br&gt;重建 model messages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="10" vertex="1">
                    <mxGeometry x="40" y="430" width="230" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="15" value="STREAMING_STEP&lt;br&gt;调用 /agent/stream&lt;br&gt;for await chunk =&gt; parser.consume(chunk)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="10" vertex="1">
                    <mxGeometry x="40" y="580" width="230" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="16" value="EXECUTE_TOOL&lt;br&gt;仅在完整 tool_call 就绪后进入&lt;br&gt;先 seal 当前 draftText，再执行工具" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="10" vertex="1">
                    <mxGeometry x="390" y="580" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="17" value="STEP_DECISION&lt;br&gt;tool_result 已返回&lt;br&gt;stepIndex += 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="10" vertex="1">
                    <mxGeometry x="390" y="730" width="220" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="18" value="FINALIZE_TURN&lt;br&gt;seal draftText&lt;br&gt;必要时补 output&lt;br&gt;queue.enqueue(turn_end)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="10" vertex="1">
                    <mxGeometry x="390" y="900" width="220" height="90" as="geometry"/>
