                <mxCell id="30" value="Persist Sidecar" style="swimlane;startSize=30;rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2f0;strokeColor=#b85450;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1360" y="180" width="390" height="760" as="geometry"/>
