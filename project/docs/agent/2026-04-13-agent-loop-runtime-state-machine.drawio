                <mxCell id="33" value="FLUSH_APPEND&lt;br&gt;串行 POST /agent/event&lt;br&gt;expected_event_count 仅在 2xx 后递增" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="30" vertex="1">
