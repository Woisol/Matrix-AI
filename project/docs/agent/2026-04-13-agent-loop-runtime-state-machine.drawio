                <mxCell id="19" value="ABORTING&lt;br&gt;abortController.abort()&lt;br&gt;停止继续拉流 / 调工具&lt;br&gt;只落已完成事件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="10" vertex="1">
